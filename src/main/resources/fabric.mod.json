    "icon": "assets/speedrunpp/icon.png",
    "environment": "*",
    "entrypoints": {
        "main": ["com.speedrunpp.SpeedrunMod"],
        "client": ["com.speedrunpp.client.SpeedrunModClient"]
    },
    "mixins": ["speedrunpp.mixins.json"],
    "depends": {
        "fabricloader": ">=0.16.0",
        "minecraft": "~1.21.1",
        "java": ">=21",
        "fabric-api": "*"
    }
}
